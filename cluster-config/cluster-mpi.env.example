# Copy to cluster-config/cluster-mpi.env and adjust values.

# SSH used by cluster-mpi.sh
SSH_USER="ec2-user"
SSH_PORT=22
SSH_KEY="${HOME}/.ssh/your-key.pem"
SSH_OPTIONS=(
  -o StrictHostKeyChecking=accept-new
  -o ConnectTimeout=10
)

# Where the repo should live on each node.
REMOTE_REPO_DIR="/home/ec2-user/N-Body-Problem-StarPU-OpenMP"

# Optional raw strings for IPs.
# Accepted formats:
#   ['123.123.123.123','111.111.111.111']
#   123.123.123.123,111.111.111.111
# Leave empty if you use: ./cluster-config/cluster-mpi.sh set-ips "..."
CONTROL_IPS_RAW=""

# Optional MPI network IPs. Use this if you SSH with public IPs but MPI should run on private IPs.
# If empty and AUTO_RESOLVE_MPI_PRIVATE_IPS=1, private IPs are auto-resolved over SSH.
# If empty and AUTO_RESOLVE_MPI_PRIVATE_IPS=0, MPI IPs fall back to CONTROL_IPS.
MPI_IPS_RAW=""

# If MPI_IPS_RAW is empty, resolve private IPs over SSH from control nodes.
AUTO_RESOLVE_MPI_PRIVATE_IPS=1

# Rank/launch preferences.
# If this IP is present in MPI IPs it is placed first in generated hostfile.
PREFERRED_MASTER_IP="10.0.0.10"

# If set, mpirun is launched from this control IP. If empty, first control IP (or preferred if present).
CONTROL_MASTER_IP=""

# You said 1 slot per machine; keep this as 1.
SLOTS_PER_HOST=1

# Build defaults used by `build` and `all`.
BUILD_TARGET="starpu"
BUILD_ARGS="USE_MPI=1 USE_CUDA=0 DEBUG=1"
BUILD_CLEAN_FIRST=0

# Run defaults used by `run` and `all`.
RUN_TARGET="starpu"
RUN_ARGS="--mpi --cpu --exp 18"
RUN_NP=""           # empty => hosts * slots
RUN_HOSTFILE=""     # optional local hostfile override
MPIRUN_BIN="mpirun"
MPIRUN_ARGS=""      # e.g. "--bind-to board"
MPIRUN_RSH_ARGS="-i ~/.ssh/id_ed25519_mpi -o StrictHostKeyChecking=accept-new"
AUTO_PREPARE_MPI_SSH=1

# Trace fetch/condense defaults.
# If empty, fetch-traces auto-detects remote path from STARPU_FXT_PREFIX or ~/starpu_traces/fxt.
REMOTE_TRACE_DIR=""
TRACE_TOOL_BIN="starpu_fxt_tool"
