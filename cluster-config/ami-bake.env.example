# Copy to cluster-config/ami-bake.env and fill values.

# AWS region used by aws cli.
REGION="us-east-1"

# Base AMIs to start from when baking each node type.
# Pick AMIs compatible with your architecture and desired distro.
BASE_AMI_CPU="ami-xxxxxxxxxxxxxxxxx"
BASE_AMI_CUDA="ami-yyyyyyyyyyyyyyyyy"

# Builder instance types (temporary EC2 used to produce AMI).
INSTANCE_TYPE_CPU="c7i.2xlarge"
INSTANCE_TYPE_CUDA="g5.xlarge"

# Network for the builder instance.
SUBNET_ID="subnet-xxxxxxxx"
SECURITY_GROUP_IDS=("sg-xxxxxxxx")

# Optional IAM profile name attached to the builder instance.
IAM_INSTANCE_PROFILE=""

# EC2 key pair name attached at launch (for SSH access).
KEY_NAME="your-ec2-keypair"

# SSH settings used by this script to run setup-*.sh remotely.
SSH_USER="ec2-user"
SSH_PORT=22
SSH_KEY="${HOME}/.ssh/your-key.pem"
SSH_OPTIONS=(
  -o StrictHostKeyChecking=accept-new
  -o ConnectTimeout=10
)

# Choose which instance IP to SSH into: public or private.
BAKE_SSH_ADDRESS="public"

# Optional AMI naming/description controls.
AMI_NAME_PREFIX="nbody-starpu"
AMI_DESCRIPTION_PREFIX="N-Body StarPU/OpenMP"
INCLUDE_INSTANCE_TYPE_IN_AMI_NAME=1

# Root disk size for builder instance (GiB).
ROOT_VOLUME_SIZE_GB=50

# Behavior toggles.
KEEP_BUILDER=0
WAIT_IMAGE=1
WAIT_INSTANCE_TIMEOUT_SECS=1800
WAIT_IMAGE_TIMEOUT_SECS=3600
WAIT_POLL_SECONDS=10
